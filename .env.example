# Telegram Bot — отримай токен у @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Chat ID — відправ /start боту, потім дізнайся ID через https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=-1001234567890

# Meta Pixel ID — Events Manager → Data Sources → Pixel → Settings.
# Поки порожній — трекінг вимкнений (безпечний no-op). Додати значення
# сюди (і в Vercel Settings → Environment Variables) і зробити redeploy —
# ViewContent/AddToCart/Purchase почнуть відправлятись автоматично,
# без правок коду.
NEXT_PUBLIC_META_PIXEL_ID=
